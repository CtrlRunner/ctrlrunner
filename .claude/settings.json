{
  "permissions": {
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(git rm /:*)",
      "Bash(sudo*)",
      "Bash(shutdown*)",
      "Bash(reboot*)",
      "Read(file:./.env)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/oleksii.galagan/.local/bin/graphify hook-guard search"
          }
        ]
      },
      {
        "matcher": "Read|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/oleksii.galagan/.local/bin/graphify hook-guard read"
          }
        ]
      }
    ]
  }
}