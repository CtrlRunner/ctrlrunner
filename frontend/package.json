{
  "name": "ctrlrunner-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && biome check src && vite build && vite build -c vite.ui.config.ts",
    "dev:ui": "vite -c vite.ui.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "format": "biome check --write src"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vite-plugin-singlefile": "^2.1.0"
  }
}
